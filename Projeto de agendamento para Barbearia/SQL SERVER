SELECT 
    barbeiros.nome_barbeiro,
    clientes.nome,
    agendamentos.id_agendamentos
FROM agendamentos
INNER JOIN barbeiros ON agendamentos.barbeiro_id = barbeiros.id_barbeiros
INNER JOIN clientes ON agendamentos.cliente_id = clientes.id_cliente;
